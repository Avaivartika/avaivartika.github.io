---
import EntryCard from "@/components/EntryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedCollection } from "@/lib/content";
import { formatDate } from "@/lib/site";

const entries = await getPublishedCollection("projects");
---

<BaseLayout title="Projects">
  <section class="list-page">
    <div class="section-kicker">Archive / Projects</div>
    <h1>项目地图</h1>
    <p class="lead">适合放进行中的产品、实验和开源工作。</p>
    <div class="grid-list">
      {entries.map((entry) => (
        <EntryCard
          href={`/projects/${entry.id}/`}
          title={entry.data.title}
          description={entry.data.description}
          meta={`${formatDate(entry.data.date)} / ${entry.data.status}`}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
