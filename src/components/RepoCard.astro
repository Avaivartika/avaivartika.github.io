---
import { formatDate } from "@/lib/site";

interface Props {
  repo: {
    name: string;
    description: string;
    url: string;
    language?: string;
    stars: number;
    updatedAt: string;
  };
}

const { repo } = Astro.props;
---

<a href={repo.url} class="repo-card card" target="_blank" rel="noreferrer">
  <div class="entry-meta">GitHub / {repo.language ?? "Mixed"}</div>
  <h3>{repo.name}</h3>
  <p>{repo.description}</p>
  <div class="repo-footer">
    <span>★ {repo.stars}</span>
    <span>Updated {formatDate(new Date(repo.updatedAt))}</span>
  </div>
</a>
